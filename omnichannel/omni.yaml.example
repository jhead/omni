# Copy to omni.yaml. `ipcSocketPath` is resolved against the process cwd (run `bun run gateway` from the project dir).
#
# Each channel `plugin` must be the npm package name (no @scope), e.g. `channel-webhook` → `@omnibot/channel-webhook`.
#
# Discord bot token resolution (first match wins):
#   1) `discord.token` below
#   2) `token` on a `plugin: channel-discord` channel
#   3) env: DISCORD_BOT_TOKEN (or `gateway.discordBotTokenEnv`)
discord:
  # token: "your-bot-token"

gateway:
  # httpHostname: "127.0.0.1"   # default: localhost only. Set to "0.0.0.0" to listen on all interfaces.
  httpPort: 8080
  ipcSocketPath: ./omni-gateway.sock
  dbPath: ./data/omni.sqlite
  sharedSecret: null
  queueTtlSeconds: 86400
  # discordBotTokenEnv: DISCORD_BOT_TOKEN   # env var name for fallback token (default DISCORD_BOT_TOKEN)
  # replyHandleTtlSeconds: 604800           # reply routing cache TTL (default 7d)

channels:
  demo:
    plugin: channel-webhook

  # Package: `@omnibot/channel-alertmanager` → POST http://<host>:<port>/alertmanager/<channelId>
  # Optional: `bearerToken` — then Alertmanager must send Authorization: Bearer <token> (see http_config bearer_token).
  # alerts:
  #   plugin: channel-alertmanager
  #   # bearerToken: "shared-secret"

  # Package: `@omnibot/channel-discord` → plugin id `channel-discord`.
  # If you see "Used disallowed intents": Developer Portal → Bot → Privileged Gateway Intents →
  # enable MESSAGE CONTENT INTENT (required to read message text). Guilds + GuildMessages + GuildMessageReactions are non-privileged.
  # discord-lounge:
  #   plugin: channel-discord
  #   discordChannelId: "1234567890123456789"
  #   # token: "optional override; otherwise use top-level discord.token or DISCORD_BOT_TOKEN"
