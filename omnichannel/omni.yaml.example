# Copy to omni.yaml. `ipcSocketPath` is resolved against the process cwd (run `bun run gateway` from the project dir).
#
# Each channel `plugin` must be the npm package name (no @scope), e.g. `channel-webhook` ‚Üí `@omnibot/channel-webhook`.
#
# Discord bot token resolution (first match wins):
#   1) `discord.token` below
#   2) `token` on a `plugin: channel-discord` channel
#   3) env: DISCORD_BOT_TOKEN (or `gateway.discordBotTokenEnv`)
discord:
  # token: "your-bot-token"

gateway:
  # httpHostname: "127.0.0.1"   # default: localhost only. Set to "0.0.0.0" to listen on all interfaces.
  httpPort: 8080
  ipcSocketPath: ./omni-gateway.sock
  dbPath: ./data/omni.sqlite
  sharedSecret: null
  queueTtlSeconds: 86400
  # discordBotTokenEnv: DISCORD_BOT_TOKEN   # env var name for fallback token (default DISCORD_BOT_TOKEN)
  # replyHandleTtlSeconds: 604800           # reply routing cache TTL (default 7d)

channels:
  demo:
    plugin: channel-webhook

  # Package: `@omnibot/channel-alertmanager` ‚Üí POST http://<host>:<port>/alertmanager/<channelId>
  # Optional: `bearerToken` ‚Äî then Alertmanager must send Authorization: Bearer <token> (see http_config bearer_token).
  # alerts:
  #   plugin: channel-alertmanager
  #   # bearerToken: "shared-secret"

  # Package: `@omnibot/channel-discord` ‚Üí plugin id `channel-discord`.
  # If you see "Used disallowed intents": Developer Portal ‚Üí Bot ‚Üí Privileged Gateway Intents ‚Üí
  # enable MESSAGE CONTENT INTENT (required to read message text). Guilds + GuildMessages + GuildMessageReactions are non-privileged.
  # discord-lounge:
  #   plugin: channel-discord
  #   discordChannelId: "1234567890123456789"
  #   # token: "optional override; otherwise use top-level discord.token or DISCORD_BOT_TOKEN"

  # Package: `@omnibot/channel-o2o` ‚Äî omni-to-omni between two gateway processes (separate omni.yaml, port, db, IPC each).
  # Egress: `peerUrl` + optional `headers`, `timeoutMs` ‚Äî `omni_dispatch` capability `send` POSTs JSON to the peer.
  # Ingress: `ingressSecret` ‚Äî peers POST JSON to http://<host>:<port>/o2o/<channelId> with Authorization: Bearer <ingressSecret>.
  # Typical pair: gateway A has an egress channel whose peerUrl is gateway B‚Äôs /o2o/<inboxChannelId>; gateway B defines that inbox with the same shared secret in `headers` and `ingressSecret`.
  # o2o_out:
  #   plugin: channel-o2o
  #   peerUrl: http://127.0.0.1:8081/o2o/o2o_in
  #   timeoutMs: 120000
  #   headers:
  #     Authorization: Bearer replace-with-shared-secret
  # o2o_in:
  #   plugin: channel-o2o
  #   ingressSecret: replace-with-shared-secret
